# Copy this to oracle.env and fill in your key to use the HTTP oracle backend.
#   cp oracle.env.example oracle.env
# oracle.env lives NEXT TO THE BINARY — on the device that is the app folder,
# e.g. /home/root/xovi/exthome/appload/riddle/oracle.env. (`remagic config
# riddle` writes it there for you.)
#
# Any OpenAI-compatible, vision-capable endpoint works.

RIDDLE_OPENAI_KEY=sk-your-key-here

# Optional — defaults shown:
# RIDDLE_OPENAI_BASE=https://api.openai.com/v1
# RIDDLE_OPENAI_MODEL=gpt-4o-mini

# Runaway guard on the reply. Thinking models (Gemini 3.x, o-series…) count
# their hidden reasoning tokens against this, so keep it roomy — a tight cap
# cuts the visible reply down to a single sentence.
# RIDDLE_OPENAI_MAX_TOKENS=2000

# For reasoning models only: sent as "reasoning_effort" when set. "low" makes
# the ink start sooner. Leave unset for non-reasoning models — some providers
# reject the field.
# RIDDLE_OPENAI_REASONING=low

# Example: OpenRouter
# RIDDLE_OPENAI_BASE=https://openrouter.ai/api/v1
# RIDDLE_OPENAI_MODEL=openai/gpt-4o-mini

# Example: Gemini (OpenAI-compatible endpoint)
# RIDDLE_OPENAI_BASE=https://generativelanguage.googleapis.com/v1beta/openai
# RIDDLE_OPENAI_MODEL=gemini-3.5-flash
# RIDDLE_OPENAI_REASONING=low

# --- pi backend (used only when RIDDLE_OPENAI_KEY is not set) ---
# Where pi lives and what it runs. Defaults shown. Note: pi keeps its own
# session history under its data dir; the HTTP backend keeps nothing.
# RIDDLE_PI_BIN_DIR=/home/root/node/bin
# RIDDLE_PI_PROVIDER=openai-codex
# RIDDLE_PI_MODEL=gpt-5.4-mini

# --- the diary's memory ---
# The diary remembers finished pages (your pen strokes, a transcription, and
# Tom's reply) in /home/root/riddle-data/memories, entirely on the tablet.
# Recent pages ride along with each request so Tom can follow a conversation,
# and writing "show me…" conjures a past page back in your own hand.
# RIDDLE_MEMORY=off          # forget nothing more, remember nothing new
# RIDDLE_MEMORY_DIR=/home/root/riddle-data/memories
# RIDDLE_MEMORY_TURNS=6      # how many recent pages Tom carries into a reply
# RIDDLE_TZ_OFFSET=-4        # hours from UTC, so memory dates read right

# --- debugging ---
# Keep the committed page at /tmp/riddle-page.png after each turn instead of
# deleting it once the oracle has read it. Handy with `riddle --oracle-test`.
# RIDDLE_KEEP_PAGE=1
